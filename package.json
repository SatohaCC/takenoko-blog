{
  "name": "blog-app",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24.14.1"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md,mdx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md,mdx}\"",
    "prepare": "panda codegen && panda cssgen",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest",
    "test:e2e": "playwright test",
    "test:ui": "playwright test --ui",
    "test:update": "playwright test --update-snapshots"
  },
  "dependencies": {
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.562.0",
    "next": "^16.2.6",
    "next-mdx-remote-client": "^2.1.7",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-aria-components": "^1.14.0",
    "react-dom": "19.2.3",
    "rehype-pretty-code": "^0.14.1",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^3.20.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.2",
    "@pandacss/dev": "^1.8.0",
    "@pandacss/eslint-plugin": "^0.3.2",
    "@playwright/test": "^1.59.1",
    "@storybook/addon-a11y": "^10.4.2",
    "@storybook/addon-docs": "^10.4.2",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-vitest": "^10.4.2",
    "@storybook/nextjs-vite": "^10.4.2",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/browser-playwright": "^4.1.6",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-storybook": "^10.4.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "playwright": "^1.58.1",
    "postcss": "^8.5.14",
    "prettier": "^3.7.4",
    "storybook": "^10.4.2",
    "typescript": "^5",
    "vite": "^7.3.1",
    "vitest": "^4.1.6"
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Safari versions",
    "last 2 Edge versions",
    "not dead"
  ]
}
